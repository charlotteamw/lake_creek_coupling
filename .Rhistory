library(ggspatial)
file_path <- getwd()
# ---------------------------------------------------------------------------
# Load basemap layers
# ---------------------------------------------------------------------------
waterbodies  <- st_read(file.path(file_path, "Data/Lakes_Streams/WaterbodyPolygons.shp"))
